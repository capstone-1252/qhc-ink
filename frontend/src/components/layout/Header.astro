---
// src/components/layout/Header.astro
import logomark from '../../assets/logomark.svg'; 
import Link from '../ui/Link.astro';

interface Props {
    links: {
        label: string;
        url: string;
    }[]
}

const {links} = Astro.props as Props; 
---

<header class="bg-white shadow-sm border-b border-gray-100 sticky top-0 z-1000">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <h1 class="shrink-0">
            <a href="/" class="flex items-center">
                <img src={logomark.src} alt="Little Wolf Restaurant" class="h-10 w-auto">
            </a>
        </h1>
        <ul class="hidden md:flex space-x-8">
            {links.map(link => (
                <li>
                    <a href={link.url} class="text-gray-700 hover:text-gray-900 font-medium transition-colors py-2">
                        {link.label}
                    </a>
                </li>
            ))}
        </ul>
        <Link href="/reservations" class="ml-4" label='Reservations'/>
    </nav>
</header>
