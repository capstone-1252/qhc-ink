---
import logomark from '../../assets/logomark.svg';

const navLinks = [
  { label: 'Menu', url: '/menu', external: false, isButton: false },
  { label: 'Food Bank', url: '/food-bank', external: false, isButton: false },
];
---

<header>
  <div class="header-inner">

    <h1 class="logo">
      <a href="/">
        <img src={logomark.src} alt="Little Wolf Restaurant home" />
      </a>
    </h1>

    <nav 
      id="main-menu"
      class="main-nav"
      aria-label="Main navigation"
    >
      <!-- Mobile close button -->
      <button
        id="mobile-close-button"
        class="mobile-close"
        type="button"
        aria-label="Close navigation menu"
      >
        <svg width="45" height="45" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <ul class="nav-list">
        {navLinks.map((link) => (
          <li>
            <a 
              href={link.url}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile bottom bar -->
      <div class="nav-footer">
        <a 
          href="https://maps.google.com/?q=Little+Wolf+Restaurant+Edmonton"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Find us on Google Maps"
          class="map-link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </a>
        <a 
          href="https://www.exploretock.com/little-wolf-restaurant"
          target="_blank"
          rel="noopener noreferrer"
          class="reservations-link"
        >
          Reservations
        </a>
      </div>
    </nav>

    <!-- Desktop reservations button -->
    <a
      href="https://www.exploretock.com/little-wolf-restaurant"
      target="_blank"
      rel="noopener noreferrer"
      class="reservations-link desktop-reservations"
    >
      Reservations
    </a>

    <div id="nav-overlay" class="nav-overlay"></div>

    <button
      id="mobile-menu-button"
      class="mobile-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="main-menu"
      aria-label="Toggle main menu"
    >
      <svg width="45" height="45" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const closeButton = document.getElementById('mobile-close-button');
  const menu = document.getElementById('main-menu');
  const overlay = document.getElementById('nav-overlay');

  function openMenu() {
    button.setAttribute('aria-expanded', 'true');
    menu.classList.add('nav-open');
    overlay.classList.add('nav-open');
    document.body.classList.add('overflow-hidden');
    menu.querySelector('a')?.focus();
  }

  function closeMenu() {
    button.setAttribute('aria-expanded', 'false');
    menu.classList.remove('nav-open');
    overlay.classList.remove('nav-open');
    document.body.classList.remove('overflow-hidden');
    button.focus();
  }

  if (button && menu && overlay) {
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      isExpanded ? closeMenu() : openMenu();
    });

    closeButton?.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && button.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });

    menu.querySelectorAll('a[href]').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>

<style>
  header {
    background-color: var(--color-espresso);
    border-bottom: 1px solid var(--color-leather);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    margin: 0;
    font-size: 1rem;
  }

  .logo img {
    height: 55px;
    width: auto;
    filter: brightness(0) saturate(100%) invert(89%) sepia(14%) saturate(400%) hue-rotate(5deg) brightness(98%) contrast(90%);
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-list a {
    color: var(--color-cream);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .nav-list a:hover {
    color: var(--color-rust);
  }

  .reservations-link {
    background-color: #C9A84C;
    color: var(--color-espresso) !important;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    transition: background-color 0.2s;
    white-space: nowrap;
  }

  .reservations-link:hover {
    background-color: #b8963e;
    color: var(--color-espresso) !important;
  }

  .desktop-reservations {
    display: block;
  }

  .nav-footer {
    display: none;
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-cream);
    padding: 0.5rem;
  }

  .mobile-close {
    display: none;
  }

  .nav-hidden {
    display: none;
  }

  .nav-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-toggle {
      display: block;
    }

    .desktop-reservations {
      display: none;
    }

    .main-nav {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: 280px;
      background-color: var(--color-leather);
      border-radius: 0 0 0 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      padding: 2rem;
      z-index: 200;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .main-nav.nav-open {
      transform: translateX(0);
    }

.mobile-close {
  display: flex;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-cream);
  padding: 0.5rem;
  position: absolute;
  top: 1rem;
  right: 2rem;
  z-index: 201;
  align-items: center;
  justify-content: center;
}

    .nav-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 199;
    }

    .nav-overlay.nav-open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-end;
      gap: 0;
    }

    .nav-list li:not(.nav-instagram) {
      width: 100%;
      border-bottom: 1px solid var(--color-rust);
      padding: 1rem 0;
      text-align: right;
    }

    .nav-instagram {
      padding-top: 1rem;
      width: 100%;
      text-align: right;
      border-bottom: 1px solid var(--color-rust);
      padding-bottom: 1rem;
    }

    .nav-list a {
      font-size: 1.2rem;
      font-weight: 700;
    }

    .nav-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 1rem;
    }

    .map-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background-color: var(--color-cream);
      color: var(--color-espresso);
      transition: background-color 0.2s;
    }

    .map-link:hover {
      background-color: var(--color-rust);
      color: var(--color-cream);
    }
  }
</style>