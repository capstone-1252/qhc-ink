--- 
import Map from "../ui/Map.astro"; 
--- 

<footer class="bg-gray-900 text-white py-16 px-4" role="contentinfo">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-start">
    <div class="md:col-span-1">
      <Map />
    </div>
    
    <div class="space-y-8">
      <div>
        <h2 class="text-2xl md:text-3xl font-black mb-4">Hours & Locations</h2>
        <div class="space-y-3 text-lg">
          <p>Fetch Editable Content</p>
          <address class="not-italic font-medium mt-4">
            123 Wolf Street, Edmonton, AB T5J 2Z1
          </address>
        </div>
      </div>
      
      <div>
        <h3 class="text-xl font-bold mb-4">Other Inquiries?</h3>
        <p class="text-gray-300 mb-4">
          Reservations, private events, or general questions
        </p>
        <a 
          href="mailto:info@littlewolf.com" 
          class="group inline-flex items-center text-lg font-semibold text-amber-400 hover:text-amber-300 transition-colors"
          aria-label="Send email to Little Wolf Restaurant"
        >
          Contact Us
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
  
  <div class="border-t border-gray-800 mt-16 pt-8 text-center text-gray-400 text-sm">
    <p>&copy; 2026 Little Wolf Restaurant. All rights reserved. Edmonton, Alberta.</p>
  </div>
</footer>
