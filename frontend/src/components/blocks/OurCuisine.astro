---
import WaveDivider from '../ui/WaveDivider.astro';
import Link from '../ui/Link.astro';
---

<section class="our-cuisine" role="region" aria-labelledby="cuisine-heading">

  <div class="our-cuisine-inner">
    <div class="our-cuisine-text">
      <h2 id="cuisine-heading" class="our-cuisine-heading">Our Cuisine</h2>
      <p>
        While we do focus on a veg forward inclusive menu we borrow from our
        rich cultural mosaic to bring exciting food from all over the world.
        We're proud to show you what we can do! Sometimes our menu changes
        faster than the weather.
      </p>
    </div>
    <div class="our-cuisine-photos">
      <img
        src="/slide-1.webp"
        alt="Wood-fired steak with seasonal vegetables - Little Wolf signature dish"
        loading="lazy"
        
        class="cuisine-photo"
      />
      <img
        src="/slide-2.webp"
        alt="House-made pasta with foraged mushrooms and truffle"
        loading="lazy"
      
        class="cuisine-photo"
      />
      <img
        src="/slide-3.webp"
        alt="Artisanal dessert featuring local berries and housemade gelato"
        loading="lazy"
       
        class="cuisine-photo"
      />
    </div>

    <div class="our-cuisine-cta">
      <Link href="/menu" label="View Menu" size="md" variant="outline" />
    </div>
  </div>

  
</section>

<style>
  .our-cuisine {
    background-color: var(--color-espresso);
    overflow: hidden;
  }

  .our-cuisine-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .our-cuisine-heading {
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      color: var(--color-cream);
   }

   .our-cuisine-text {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
   }

  .our-cuisine-text p {
    color: var(--color-cream);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 55ch;
  }

  /* 3-photo grid */
  .our-cuisine-photos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .cuisine-photo {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

.our-cuisine-cta {
  display: flex;
  align-items: flex-start;
}


  /* Mobile */
  @media (max-width: 768px) {
    .our-cuisine-inner {
    padding: 3rem 1.5rem 3.5rem;
    gap: 2rem;
  }
  .our-cuisine-cta {
    justify-content: center;
  }
  .our-cuisine-photos {
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 0.75rem;
  height: 60vw;
}
  .cuisine-photo:first-child {
    grid-column: 1;
    grid-row: 1 / 3;
    height: 100%;
    aspect-ratio: unset;
  }
  .cuisine-photo:not(:first-child) {
    grid-column: 2;
    height: 100%;
    aspect-ratio: unset;
  }
}
</style>