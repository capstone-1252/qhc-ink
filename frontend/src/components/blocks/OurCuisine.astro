---
import WaveDivider from '../ui/WaveDivider.astro';
import Link from '../ui/Link.astro';
---

<section class="our-cuisine" role="region" aria-labelledby="cuisine-heading">

  <div class="our-cuisine-inner">
    <div class="our-cuisine-text">
      <h2 id="cuisine-heading" class="our-cuisine-heading">Our Cuisine</h2>
      <p>
        While we do focus on a veg forward inclusive menu we borrow from our
        rich cultural mosaic to bring exciting food from all over the world.
        We're proud to show you what we can do! Sometimes our menu changes
        faster than the weather.
      </p>
    </div>
    <div class="our-cuisine-photos">
      <picture class="cuisine-picture">
        <source media="(max-width: 768px)" srcset="/images/our-cuisine/cuisine-tomato-mobile.webp" />
        <img src="/images/our-cuisine/cuisine-tomato.webp" alt="Roasted tomato dish at Little Wolf Restaurant" loading="lazy" class="cuisine-photo" />
      </picture>
      <picture class="cuisine-picture">
        <source media="(max-width: 768px)" srcset="/images/our-cuisine/cuisine-mush-soup-mobile.webp" />
        <img src="/images/our-cuisine/cuisine-mush-soup.webp" alt="Mushroom soup with garnish at Little Wolf Restaurant" loading="lazy" class="cuisine-photo" />
      </picture>
      <picture class="cuisine-picture">
        <source media="(max-width: 768px)" srcset="/images/our-cuisine/cuisine-bread-mobile.webp" />
        <img src="/images/our-cuisine/cuisine-bread.webp" alt="Freshly baked bread with accompaniments at Little Wolf Restaurant" loading="lazy" class="cuisine-photo" />
      </picture>
    </div>

    <div class="our-cuisine-cta">
      <Link href="/menu" label="View Menu" size="md" variant="outline" />
    </div>
  </div>

</section>

<style>
  .our-cuisine {
    background-color: var(--color-espresso);
    overflow: hidden;
  }

  .our-cuisine-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .our-cuisine-heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-cream);
  }

  .our-cuisine-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .our-cuisine-text p {
    color: var(--color-cream);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 55ch;
  }

  /* 3-photo grid */
  .our-cuisine-photos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

 .cuisine-picture {
  display: block;
  border-radius: 0.75rem;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
}

.cuisine-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

  .our-cuisine-cta {
    display: flex;
    align-items: flex-start;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .our-cuisine-inner {
      padding: 3rem 1.5rem 3.5rem;
      gap: 2rem;
    }

    .our-cuisine-cta {
      justify-content: center;
    }

    .our-cuisine-photos {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 0.75rem;
      height: 60vw;
    }

    .cuisine-picture {
      aspect-ratio: unset;
      height: 100%;
      border-radius: 0.75rem;
    }

    .cuisine-picture:first-child {
      grid-column: 1;
      grid-row: 1 / 3;
    }

    .cuisine-picture:not(:first-child) {
      grid-column: 2;
    }
  }
</style>