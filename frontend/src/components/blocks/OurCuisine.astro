---
import Link from '../ui/Link.astro';

---

<section role="region" aria-labelledby="cuisine-heading">
  <div>
    <h2 id="cuisine-heading">
      Our Cuisine
    </h2>
    <p>
      Seasonal ingredients, masterful technique, unforgettable flavor.
    </p>
  </div>
  
  <div>
    <div>
      <p>
        Our cuisine celebrates Alberta's finest seasonal ingredients, transformed through classical techniques 
        and modern innovation. Each plate reflects our commitment to flavor harmony and visual artistry.
      </p>
      <p>
        From house-made pastas to wood-fired proteins, every element receives meticulous attention to detail.
      </p>
    </div>
  </div>

  <div>
    <img 
      src="/slide-1.webp" 
      alt="Wood-fired steak with seasonal vegetables - Little Wolf signature dish"
      loading="lazy"
      width="400"
      height="256"
    >
    <img 
      src="/slide-2.webp" 
      alt="House-made pasta with foraged mushrooms and truffle"
      loading="lazy"
      width="400"
      height="256"
    >
    <img 
      src="/slide-3.webp" 
      alt="Artisanal dessert featuring local berries and housemade gelato"
      loading="lazy"
      width="400"
      height="256"
    >
  </div>

  <div>
    <Link label="View Menu" size='lg' />
  </div>
</section>