---
import WaveDivider from '../ui/WaveDivider.astro';
import FAQAccordion from './FAQAccordion.jsx';
---

<section class="faqs" aria-labelledby="faq-heading">
  <div class="faqs-inner">

    <div class="faqs-mascot">
      <img src="/primary-logo.svg" alt="" aria-hidden="true" />
    </div>

    <div class="faqs-content">
      <h2 id="faq-heading" class="faqs-heading">FAQ</h2>
      <FAQAccordion client:load />
    </div>

  </div>

  <WaveDivider fill="var(--color-cream)" />
</section>

<style>
  .faqs {
    background-color: var(--color-leather);
    overflow: hidden;
  }

  .faqs-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: center;
  }

  .faqs-mascot img {
    width: 100%;
    max-width: 250px;
    opacity: 0.85;
    display: block;
  }

  .faqs-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .faqs-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-rust);
    text-align: center;
    font-family: var(--font-body);
    font-weight: 700;
  }

  /* Accordion styles — global so they apply to the React component */
  :global(.faq-accordion) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.faq-item) {
    background-color: var(--color-cream);
    border: 2px solid var(--color-rust);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  :global(.faq-trigger) {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-espresso);
    text-align: left;
  }

  :global(.faq-trigger:hover) {
    color: var(--color-rust);
  }

  :global(.faq-chevron) {
    flex-shrink: 0;
    color: var(--color-rust);
    transition: transform 0.25s ease;
  }

  :global([data-state="open"] .faq-chevron) {
    transform: rotate(180deg);
  }

  :global(.faq-content) {
    overflow: hidden;
  }

  :global(.faq-content[data-state="open"]) {
    animation: slideDown 0.25s ease;
  }

  :global(.faq-content[data-state="closed"]) {
    animation: slideUp 0.25s ease;
  }

  :global(.faq-content-inner) {
    padding: 0 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  :global(.faq-content-inner p) {
    font-size: 0.9rem;
    color: var(--color-leather);
    line-height: 1.7;
    max-width: unset;
  }

  @keyframes slideDown {
    from { height: 0; opacity: 0; }
    to { height: var(--radix-accordion-content-height); opacity: 1; }
  }

  @keyframes slideUp {
    from { height: var(--radix-accordion-content-height); opacity: 1; }
    to { height: 0; opacity: 0; }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .faqs-inner {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 2.5rem;
      gap: 2rem;
    }

    .faqs-mascot {
      display: none;
    }
  }
</style>