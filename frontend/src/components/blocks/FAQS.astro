---
import Button from "../ui/Button.astro";
---


<section class="faq-section py-24 px-4 max-w-4xl mx-auto" aria-labelledby="faq-heading">
  <div class="text-center mb-20">
    <h2 id="faq-heading" class="text-4xl md:text-5xl font-black text-gray-900 mb-6">
      Frequently Asked Questions
    </h2>
  </div>

  <div class="space-y-4">
    <!-- FAQ Item 1 -->
    <details class="faq-item group">
      <summary class="faq-question font-semibold text-gray-900 py-4 px-6 cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900/20 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-all duration-200">
        What are your hours of operation?
      </summary>
      <div class="faq-answer p-6 pt-2 text-gray-700 leading-relaxed border-t border-gray-200">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Tenetur laborum voluptatibus quia ducimus molestias. Rerum voluptatibus praesentium laborum facere placeat minima non.
      </div>
    </details>

    <!-- FAQ Item 2 -->
    <details class="faq-item group">
      <summary class="faq-question font-semibold text-gray-900 py-4 px-6 cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900/20 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-all duration-200">
        Do I need reservations?
      </summary>
      <div class="faq-answer p-6 pt-2 text-gray-700 leading-relaxed border-t border-gray-200">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Vero id animi ex voluptas perferendis pariatur distinctio iste quibusdam, fugiat sapiente nam praesentium soluta.
      </div>
    </details>

    <!-- FAQ Item 3 -->
    <details class="faq-item group">
      <summary class="faq-question font-semibold text-gray-900 py-4 px-6 cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900/20 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-all duration-200">
        What's the dress code?
      </summary>
      <div class="faq-answer p-6 pt-2 text-gray-700 leading-relaxed border-t border-gray-200">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Sit dolore vel facilis similique dolorum dicta temporibus voluptas quae cumque totam quas reiciendis numquam vitae.
      </div>
    </details>

    <!-- FAQ Item 4 -->
    <details class="faq-item group">
      <summary class="faq-question font-semibold text-gray-900 py-4 px-6 cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900/20 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-all duration-200">
        Do you accommodate dietary restrictions?
      </summary>
      <div class="faq-answer p-6 pt-2 text-gray-700 leading-relaxed border-t border-gray-200">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Alias culpa facilis fugit molestias sunt laborum aliquam voluptatem velit eos fugiat debitis harum similique quas.
      </div>
    </details>

    <!-- FAQ Item 5 -->
    <details class="faq-item group">
      <summary class="faq-question font-semibold text-gray-900 py-4 px-6 cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900/20 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-all duration-200">
        Where should I park?
      </summary>
      <div class="faq-answer p-6 pt-2 text-gray-700 leading-relaxed border-t border-gray-200">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Vitae odit assumenda quos officiis enim amet esse ratione perspiciatis ipsum nulla suscipit non explicabo nihil.
      </div>
    </details>
  </div>

  <div class="text-center mt-16">
    <Button href="/contact" size="lg" class="shadow-xl hover:shadow-2xl">
      Still Have Questions?
    </Button>
  </div>
</section>

