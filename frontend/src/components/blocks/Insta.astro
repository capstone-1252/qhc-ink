---
import WaveDivider from '../ui/WaveDivider.astro';
import Link from '../ui/Link.astro';
---

<section class="whats-happening" aria-labelledby="happening-heading">

  <div class="whats-happening-inner">
    <div class="whats-happening-text">
      <h2 id="happening-heading" class="whats-happening-heading">
        What's Happening at Little Wolf?
      </h2>
      <p class="whats-happening-body">
        Follow along on Instagram to see what's new and stay up to date with everything at Little Wolf.
      </p>
    </div>
    
    <div class="insta-feed" aria-label="Instagram feed">
      <div class="insta-feed-slides" id="insta-slides">
        <div class="insta-feed-slide">
          <img src="/images/insta/happening-egg.webp" alt="" role="presentation" loading="lazy" />
        </div>
        <div class="insta-feed-slide">
          <img src="/images/insta/happening-drink.webp" alt="" role="presentation" loading="lazy" />
        </div>
        <div class="insta-feed-slide">
          <img src="/images/insta/happening-duck.webp" alt="" role="presentation" loading="lazy" />
        </div>
      </div>
      <div class="insta-feed-dots" id="insta-dots">
        <button class="insta-feed-dot active" aria-label="Slide 1"></button>
        <button class="insta-feed-dot" aria-label="Slide 2"></button>
        <button class="insta-feed-dot" aria-label="Slide 3"></button>
      </div>
    </div>

    <Link
      href="https://www.instagram.com/eatlilwolf/"
      target="_blank"
      rel="noopener noreferrer"
      label="More From Us"
      variant="outline"
      size="md"
    />
  </div>

</section>

<script>
  const slides = document.getElementById('insta-slides');
  const dots = document.querySelectorAll('#insta-dots .insta-feed-dot');

  slides?.addEventListener('scroll', () => {
    const index = Math.round(slides.scrollLeft / slides.offsetWidth);
    dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      slides?.scrollTo({ left: i * slides.offsetWidth, behavior: 'smooth' });
    });
  });
</script>

<style>
  .whats-happening {
    background-color: var(--color-espresso);
    overflow: hidden;
  }

  .whats-happening-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .whats-happening-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .whats-happening-heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-gold);
  }

  .whats-happening-body {
    color: var(--color-cream);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 55ch;
  }

  .insta-feed {
    width: 100%;
  }

  .insta-feed-slides {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .insta-feed-slide {
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .insta-feed-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .insta-feed-dots {
    display: none;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .whats-happening-inner {
      padding: 4rem 1.5rem 3.5rem;
    }

    .insta-feed {
      position: relative;
    }

    .insta-feed-slides {
      display: flex;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 1rem;
    }

    .insta-feed-slides::-webkit-scrollbar {
      display: none;
    }

    .insta-feed-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }

    .insta-feed-dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .insta-feed-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: var(--color-taupe);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background-color 0.2s;
    }

    .insta-feed-dot.active {
      background-color: var(--color-cream);
    }
  }
</style>