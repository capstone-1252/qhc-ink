---
import WaveDivider from '../ui/WaveDivider.astro';
---

<section class="whats-happening" aria-labelledby="happening-heading">

  <div class="whats-happening-inner">
    <h2 id="happening-heading" class="whats-happening-heading">
      What's Happening at Little Wolf?
    </h2>
    <p class="whats-happening-body">
      Follow along on Instagram to see what's new and stay up to date with everything at Little Wolf.
    </p>

    <!-- TODO: Replace with EmblaCarousel once Bridgette gives go-ahead -->
    <!-- <EmblaCarousel client:load slides={slides} options={options} /> -->
    <div class="carousel-placeholder" aria-label="Instagram feed coming soon">
      <div class="placeholder-slides">
        <div class="placeholder-slide">
          <img src="/slide-1.webp" alt="" loading="lazy" />
        </div>
        <div class="placeholder-slide">
          <img src="/slide-2.webp" alt="" loading="lazy" />
        </div>
        <div class="placeholder-slide">
          <img src="/slide-3.webp" alt="" loading="lazy" />
        </div>
      </div>
    </div>

    <a
      href="https://www.instagram.com/littlewolfrestaurant/"
      target="_blank"
      rel="noopener noreferrer"
      class="insta-link"
    >
      More From Us
    </a>
  </div>

  
</section>

<style>
  .whats-happening {
    background-color: var(--color-espresso);
    overflow: hidden;
  }

  .whats-happening-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .whats-happening-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-cream);
  }

  .whats-happening-body {
    color: var(--color-cream);
    font-size: 0.95rem;
    max-width: 50ch;
  }

  /* Placeholder carousel — 3 images side by side */
  .carousel-placeholder {
    width: 100%;
  }

  .placeholder-slides {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .placeholder-slide {
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .placeholder-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .insta-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-cream);
    border: 2px solid var(--color-cream);
    padding: 0.75rem 1.75rem;
    border-radius: 2rem;
    transition: background-color 0.2s, color 0.2s;
    align-self: flex-start;
  }

  .insta-link:hover {
    background-color: var(--color-cream);
    color: var(--color-espresso);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .whats-happening-inner {
      padding: 3rem 1.5rem 2.5rem;
    }

    .placeholder-slides {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>