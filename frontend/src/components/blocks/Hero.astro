 <!-- Just making a really basic  -->
---
// src/components/Hero.astro

import Button from '../ui/Button.astro';
---

<section class="hero relative overflow-hidden bg-linear-to-r from-gray-900 via-stone-900 to-black py-32 md:py-40">
  <div class="absolute inset-0 bg-black/40"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 drop-shadow-2xl">
      Little Wolf Restaurant
    </h1>
    <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto opacity-95 drop-shadow-lg">
      Exceptional dining experiences with seasonal ingredients and timeless hospitality.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center max-w-md mx-auto">
      <Button href="/reservations" size="lg" class="w-full sm:w-auto" label='Reserve' variant='outline'>
      </Button>
    </div>
  </div>
</section>
