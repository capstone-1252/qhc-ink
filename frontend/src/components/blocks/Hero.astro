---
import WaveDivider from '../ui/WaveDivider.astro';
import Link from '../ui/Link.astro';
import GooglyEyes from '../GooglyEyes.astro';

/* import EmblaCarousel from '../ui/EmblaCarousel';
import HoursPanel from '../ui/HoursTab';    
import ProfileCard from '../ui/ProfileCard.astro'; */
---


<!-- const slides = [
  { img: '/slide-1.webp' },
  { img: '/slide-2.webp'},
  { img: '/slide-3.webp'}
]; -->

<section class="hero" aria-label="Hero">
  <div class="hero-inner">

    <div class="hero-content">
      <h1 class="hero-heading">
        Where Flavour<br />Meets Fun
      </h1>
      <p class="hero-body">
        Welcome to Little Wolf, Where you can drop in and hang out, (You can also secure yourself a reservation!) We're a small plates & big hearts restaurant and bar in the center of the garneau district. we specialize in craft cocktails, local beers & a veg forward menu with something for everyone.
      </p>
      <Link
        href="/reservations"
        label="Reserve"
        size="md"
        variant="outline"
      />
      <div class="eyes" data-egg-trigger>
        <GooglyEyes style="width: 70px; height: 45px;" />
      </div>
    </div>

    <div class="hero-image-wrap">
      <img
        src="/slide-1.webp"
        alt="Guests enjoying dinner at Little Wolf Restaurant in Edmonton"
        width="640"
        height="480"
        loading="eager"
        class="hero-image"
      />
    </div>

  </div>

  <WaveDivider fill="var(--color-cream)" />
</section>

<style>
  .hero {
    background-color: var(--color-leather);
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .hero-heading {
    font-family: var(--font-accent);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    color: var(--color-cream);
    line-height: 1.05;
    font-style: italic;
  }

  .hero-body {
    font-size: 0.95rem;
    color: var(--color-cream);
    max-width: 42ch;
    line-height: 1.7;
  }

  /* Image */
  .hero-image-wrap {
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* googly eyes */
  .eyes {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 4rem 1.5rem 2.5rem;
      gap: 2rem;
    }

    .hero-image-wrap {
      order: -1; /* image above text on mobile */
      aspect-ratio: 16 / 9;
      border-radius: 0.75rem;
    }

    .hero-heading {
      font-size: clamp(2.2rem, 10vw, 3rem);
    }

    .eyes {
    justify-content: flex-start;
    }
  }
</style>