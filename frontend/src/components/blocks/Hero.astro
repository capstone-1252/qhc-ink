---
import WaveDivider from '../ui/WaveDivider.astro';
import Link from '../ui/Link.astro';
import GooglyEyes from '../GooglyEyes.astro';

/* import EmblaCarousel from '../ui/EmblaCarousel';
import HoursPanel from '../ui/HoursTab';    
import ProfileCard from '../ui/ProfileCard.astro'; */
---


<!-- const slides = [
  { img: '/slide-1.webp' },
  { img: '/slide-2.webp'},
  { img: '/slide-3.webp'}
]; -->

<section class="hero" aria-label="Hero">
  <div class="hero-inner">

    <div class="hero-content">
      <h1 class="hero-heading">
        Where Flavour<br />Meets Fun
      </h1>
      <p class="hero-body">
        Welcome to Little Wolf, Where you can drop in and hang out, (You can also secure yourself a reservation!) We're a small plates & big hearts restaurant and bar in the center of the garneau district. we specialize in craft cocktails, local beers & a veg forward menu with something for everyone.
      </p>
      <Link
        href="/reservations"
        label="Reserve"
        size="md"
        variant="outline"
      />
      <div class="eyes" data-egg-trigger>
        <GooglyEyes style="width: 70px; height: 45px;" />
      </div>
    </div>

    <div class="hero-image-wrap">
      <img
        src="/slide-1.webp"
        alt="Guests enjoying dinner at Little Wolf Restaurant in Edmonton"
        width="640"
        height="480"
        loading="eager"
        class="hero-image"
      />
    </div>
  </section>
  <HoursTab client:load hours={hours} />
</div>

<style>
  .hero-wrapper {
      position: relative;
      overflow-x: hidden;
   }

  .hero {
    background-color: var(--color-leather);
    overflow: hidden;
  }

  .hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: clamp(400px, 50vw, 650px);
  position: relative;
}
  
.hero-column-divider {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  height: calc(100% + 80px);
  width: 80px;
  z-index: 2;
  pointer-events: none;
}

  .hero-column-divider svg {
    width: 100%;
    height: 100%;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 5rem 3rem 3rem max(2rem, calc((100vw - 1200px) / 2 + 2rem));
    justify-content: center;
  }

  .hero-heading {
    font-family: var(--font-accent);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    color: var(--color-cream);
    line-height: 1.05;
    font-style: italic;
  }

  .hero-body {
    font-size: 0.95rem;
    color: var(--color-cream);
    max-width: 55ch;
    line-height: 1.75;
  }

  .hero-image-wrap {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 600px;
    position: relative;
  }

  .hero-image-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-leather)
    );
    pointer-events: none;
    z-index: 1;
  }

  /* googly eyes */
  .eyes {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* Mobile */

  @media (max-width: 1024px) {
  .hero-inner {
    height: auto;
    min-height: 500px;
  }
}

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      height: calc(100svh - 72px);
      overflow: hidden;
      position: relative;
    }

    .hero-image-wrap {
      position: absolute;
      inset: 0;
      min-height: unset;
    }

    .hero-image-fade {
      display: none;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      padding: 3.5rem 1.5rem 3rem 1.5rem;
      justify-content: flex-start;
      background: linear-gradient(
         to bottom,
         rgba(35, 28, 24, 0.8) 0%,
         rgba(35, 28, 24, 0.5) 50%,
         rgba(35, 28, 24, 0.3) 100%
      );
  }

    .hero-heading {
      font-size: clamp(2.2rem, 10vw, 3rem);
    }

    .eyes {
    justify-content: flex-start;
    }
  }
</style>