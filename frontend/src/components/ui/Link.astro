---
interface Props {
    label?: string;
    variant?: 'default' | 'outline' | 'ghost';
    size?: 'sm' | 'md' | 'lg';
    disabled?: boolean;
    href?: string;
    class?: string;
    target?: string;
    rel?: string;
}

const { 
    variant = 'default', 
    size = 'md', 
    disabled = false,
    class: className = '',
    href,
    target,
    rel,
    label,
    ...props 
} = Astro.props as Props;

const baseStyles = 'items-center justify-center font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-200';
const sizes = {
    sm: 'px-3 py-1.5 text-sm',
    md: 'px-4 py-2 text-sm',
    lg: 'px-6 py-3 text-base'
};
const variants = {
    default: 'bg-gray-900 text-white hover:bg-gray-800 focus:ring-gray-500 shadow-sm',
    outline: 'border border-gray-300 bg-white text-gray-900 hover:bg-gray-50 focus:ring-gray-500',
    ghost: 'text-gray-900 hover:bg-gray-100 focus:ring-gray-500'
};
---

<a 
    href={href}
    class:list={[
        baseStyles,
        sizes[size],
        variants[variant],
        disabled && 'opacity-50 cursor-not-allowed pointer-events-none',
        className
    ]}
    target={target}
    rel={rel}
    aria-disabled={disabled || undefined}
    {...props}
>
    {label}
</a>
