---
interface Props {
  label?: string;
  variant?: 'default' | 'outline' | 'ghost' | 'gold';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
}

const { 
  variant = 'default', 
  size = 'md', 
  class: className = '',
  href,
  target,
  rel,
  label,
  disabled = false,
  ...props 
} = Astro.props as Props;
---

<a
  href={href}
  class:list={[
    'button',
    `button-${variant}`,
    `button-${size}`,
    disabled && 'button-disabled',
    className
  ]}
  target={target}
  rel={rel}
  aria-disabled={disabled || undefined}
  {...props}
>
  {label}
</a>

<style>
   .button {
   display: inline-flex;
   align-items: center;
   justify-content: center;
   font-family: var(--font-body);
   font-weight: 600;
   letter-spacing: 0.08em;
   text-transform: uppercase;
   border-radius: 2rem;
   text-decoration: none;
   transition: background-color 0.2s, color 0.2s, border-color 0.2s;
   white-space: nowrap;
   cursor: pointer;
   width: 200px;
}

  /* Sizes */
  .button-sm {
    font-size: 0.8rem;
    padding: 0.5rem 1.25rem;
  }

  .button-md {
    font-size: 0.9rem;
    padding: 0.75rem 1.75rem;
  }

  .button-lg {
    font-size: 1rem;
    padding: 0.875rem 2.25rem;
  }

  /* Variants */
  .button-default {
    background-color: var(--color-rust);
    color: var(--color-cream);
    border: 2px solid transparent;
  }

  .button-default:hover {
    background-color: var(--color-leather);
    color: var(--color-cream);
  }

  .button-outline {
    background-color: transparent;
    color: var(--color-cream);
    border: 2px solid var(--color-cream);
  }

  .button-outline:hover {
    background-color: var(--color-cream);
    color: var(--color-espresso);
  }

   .button-gold {
      background-color: var(--color-gold);
      color: var(--color-espresso);
      border: 2px solid var(--color-gold);   
   }

   .button-gold:hover {
      background-color: var(--color-rust);
      color: var(--color-gold);
   }

  .button-ghost {
    background-color: transparent;
    color: var(--color-cream);
    border: 2px solid transparent;
  }

  .button-ghost:hover {
    color: var(--color-rust);
  }

  /* Disabled */
  .button-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (max-width: 768px) {
  .button {
    align-self: center;
/*     width: 100%;
 */    text-align: center;
    justify-content: center;
  }
}
</style>