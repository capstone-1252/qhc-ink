---
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import EggEasterEgg from '../components/EggEasterEgg.astro';
import GooglyEyes from '../components/GooglyEyes.astro';
import ShakeTrigger from '../components/ShakeTrigger.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
const actualTitle = title ? `${title} | Little Wolf Restaurant` : 'Little Wolf Restaurant';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{actualTitle}</title>
    </head>
    <body>
        <slot />
        <EggEasterEgg />
        <ShakeTrigger />
        <Footer />
    </body>
</html>