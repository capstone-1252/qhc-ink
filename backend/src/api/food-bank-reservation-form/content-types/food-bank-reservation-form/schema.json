{
  "kind": "collectionType",
  "collectionName": "food_bank_reservation_forms",
  "info": {
    "singularName": "food-bank-reservation-form",
    "pluralName": "food-bank-reservation-forms",
    "displayName": "FoodBankReservationForm"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "partySize": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 200
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "maxLength": 254,
      "unique": false
    },
    "phone": {
      "type": "string",
      "minLength": 10,
      "maxLength": 11,
      "required": true,
      "regex": "^[\\d+\\-\\s]+$"
    },
    "note": {
      "type": "text",
      "maxLength": 600
    },
    "reservation_slot": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::reservation-slot.reservation-slot",
      "private": false,
      "inversedBy": "food_bank_reservation_forms"
    }
  }
}
