{
  "kind": "collectionType",
  "collectionName": "menu_items",
  "info": {
    "singularName": "menu-item",
    "pluralName": "menu-items",
    "displayName": "MenuItem"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "menu_category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::menu-category.menu-category"
    },
    "ingredients": {
      "type": "text",
      "required": false
    },
    "price": {
      "type": "decimal",
      "required": false,
      "max": 99
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "dietarySelect": {
      "type": "enumeration",
      "required": true,
      "default": "none",
      "enum": [
        "none",
        "vegan",
        "vegetarian"
      ]
    },
    "drinkSize": {
      "type": "string"
    },
    "drinkPriceGlass": {
      "type": "integer"
    },
    "drinkPriceBottle": {
      "type": "integer"
    }
  }
}
